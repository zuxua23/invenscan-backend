@using InvenScan.DTO.Response
@model List<StockTakingDetailResponse>
@{
    var session = ViewData["Session"] as StockTakingResponse;
    ViewData["Title"] = $"Session {session?.SessionCode}";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-controller="StockTakingWeb" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="page-title mb-0">Session Detail</h1>
    </div>
</div>

@if (session != null)
{
    <div class="card mb-3">
        <div class="detail-header">
            <div class="detail-header-item">
                <div class="dh-label">Session Code</div>
                <div class="dh-value"><code>@session.SessionCode</code></div>
            </div>
            <div class="detail-header-item">
                <div class="dh-label">Status</div>
                <div class="dh-value">
                    @if (session.Status == "OPEN")
                    {
                        <span class="badge-teal">OPEN</span>
                    }
                    else
                    {
                        <span class="badge-gray">CLOSED</span>
                    }
                </div>
            </div>
            <div class="detail-header-item">
                <div class="dh-label">Total Items</div>
                <div class="dh-value">@session.TotalItems</div>
            </div>
            <div class="detail-header-item">
                <div class="dh-label">Scanned</div>
                <div class="dh-value is-teal">@session.ScannedItems</div>
            </div>
            <div class="detail-header-item">
                <div class="dh-label">Missing</div>
                <div class="dh-value is-danger">@session.MissingItems</div>
            </div>
            <div class="detail-header-item">
                <div class="dh-label">Remark</div>
                <div class="dh-value is-hint">@(string.IsNullOrWhiteSpace(session.Remark) ? "—" : session.Remark)</div>
            </div>
            <div class="detail-header-item">
                <div class="dh-label">Created</div>
                <div class="dh-value is-hint">@session.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
        </div>
    </div>
}

<div class="is-card">
    <table id="detailTable" class="table table-hover mb-0">
        <thead>
            <tr>
                <th>EPC Tag</th>
                <th>Item Code</th>
                <th>Item Name</th>
                <th>Location</th>
                <th>Action</th>
                <th>Scanned At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td><code style="font-size:11px">@d.EpcTag</code></td>
                    <td><code>@d.ItemCode</code></td>
                    <td>@d.ItemName</td>
                    <td style="color:var(--text-secondary);font-size:12px">@d.LocationCode — @d.LocationName</td>
                    <td>
                        @switch (d.Action)
                        {
                            case "SCAN":
                                <span class="badge-teal">SCAN</span>
                                break;
                            case "MISSING":
                                <span class="badge-danger">MISSING</span>
                                break;
                            default:
                                <span class="badge-gray">SYSTEM</span>
                                break;
                        }
                    </td>
                    <td style="color:var(--text-hint);font-size:12px">@(d.ScannedAt?.ToString("HH:mm:ss") ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>$(document).ready(function () { $('#detailTable').DataTable({ pageLength: 50 }); });</script>
}
