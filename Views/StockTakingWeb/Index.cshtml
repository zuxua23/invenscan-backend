@using InvenScan.DTO.Response
@model List<StockTakingResponse>
@{ ViewData["Title"] = "Stock Taking"; }

@if (User.IsInRole("ADMIN"))
{
    <div class="card p-3 mb-3">
        <form asp-controller="StockTakingWeb" asp-action="Create" method="post" class="d-flex gap-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="flex-grow-1">
                <label class="form-label fw-semibold small mb-1">New Session Remark (optional)</label>
                <input name="remark" class="form-control form-control-sm" placeholder="e.g. Monthly stock check Q1 2026" />
            </div>
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Create Session
            </button>
        </form>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table id="sttTable" class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Session Code</th>
                    <th>Remark</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th>Scanned</th>
                    <th>Missing</th>
                    <th>Created</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td><code>@s.SessionCode</code></td>
                        <td class="text-muted">@s.Remark</td>
                        <td>
                            @if (s.Status == "OPEN")
                            {
                                <span class="badge bg-success">OPEN</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">CLOSED</span>
                            }
                        </td>
                        <td>@s.TotalItems</td>
                        <td class="text-success fw-semibold">@s.ScannedItems</td>
                        <td class="text-danger fw-semibold">@s.MissingItems</td>
                        <td class="text-muted small">@s.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <a asp-controller="StockTakingWeb" asp-action="Detail" asp-route-id="@s.Id"
                               class="btn btn-sm btn-outline-primary py-0">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (s.Status == "OPEN" && User.IsInRole("ADMIN"))
                            {
                                <form asp-controller="StockTakingWeb" asp-action="Close" asp-route-id="@s.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Close session @s.SessionCode?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning py-0">
                                        <i class="bi bi-lock"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>$(document).ready(function () { $('#sttTable').DataTable({ order: [[6, 'desc']], pageLength: 25 }); });</script>
}
