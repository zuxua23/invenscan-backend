@using InvenScan.DTO.Request
@model ItemCreateRequest
@{ ViewData["Title"] = "Add Item"; }

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-controller="ItemWeb" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="page-title mb-0">Add Item</h1>
    </div>
</div>

<div style="max-width:560px">
    <div class="card p-4">
        @if (ViewData["Error"] != null)
        {
            <div class="alert-is alert-is-danger mb-3">
                <i class="bi bi-exclamation-triangle-fill"></i>@ViewData["Error"]
            </div>
        }
        <form asp-controller="ItemWeb" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Item Code <span style="color:var(--danger)">*</span></label>
                <input name="ItemCode" class="form-control" value="@Model?.ItemCode" placeholder="e.g. ITM-006" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Item Name <span style="color:var(--danger)">*</span></label>
                <input name="ItemName" class="form-control" value="@Model?.ItemName" placeholder="Item display name" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="Description" class="form-control" rows="2">@Model?.Description</textarea>
            </div>
            <div class="row">
                <div class="col-6 mb-3">
                    <label class="form-label">Unit</label>
                    <input name="Unit" class="form-control" value="@Model?.Unit" placeholder="PCS, BOX, KG..." />
                </div>
                <div class="col-6 mb-3">
                    <label class="form-label">Min Stock</label>
                    <input name="MinStock" type="number" class="form-control" value="@(Model?.MinStock ?? 0)" min="0" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-save me-1"></i>Save Item
            </button>
        </form>
    </div>
</div>
