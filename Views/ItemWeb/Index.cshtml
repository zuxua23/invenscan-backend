@using InvenScan.DTO.Response
@model List<ItemResponse>
@{ ViewData["Title"] = "Items"; }

<div class="page-header">
    <h1 class="page-title">Items</h1>
    @if (User.IsInRole("ADMIN"))
    {
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createItemModal">
            <i class="bi bi-plus-lg me-1"></i>Add Item
        </button>
    }
</div>

<div class="is-card">
    <table id="itemTable" class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Item Code</th>
                <th>Item Name</th>
                <th>Unit</th>
                <th>Min Stock</th>
                <th>Created</th>
                @if (User.IsInRole("ADMIN"))
                {
                    <th style="width:100px">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><code>@item.ItemCode</code></td>
                    <td>@item.ItemName</td>
                    <td style="color:var(--text-secondary)">@item.Unit</td>
                    <td style="color:var(--text-secondary)">@item.MinStock</td>
                    <td style="color:var(--text-hint);font-size:12px">@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                    @if (User.IsInRole("ADMIN"))
                    {
                        <td>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-sm btn-outline-secondary py-0 btn-edit-item"
                                        data-id="@item.Id"
                                        data-code="@item.ItemCode"
                                        data-name="@item.ItemName"
                                        data-desc="@(item.Description ?? "")"
                                        data-unit="@item.Unit"
                                        data-min="@item.MinStock">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger py-0 btn-delete-item"
                                        data-label="@item.ItemCode"
                                        data-delete-url="/items/delete/@item.Id">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@if (User.IsInRole("ADMIN"))
{
    <!-- Create Item Modal -->
    <div class="modal fade" id="createItemModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header is-dark">
                    <h5 class="modal-title"><i class="bi bi-box-seam me-2"></i>Add Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form id="createItemForm" action="/items/create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Item Code <span style="color:var(--danger)">*</span></label>
                            <input name="ItemCode" class="form-control" placeholder="e.g. ITM-006" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Item Name <span style="color:var(--danger)">*</span></label>
                            <input name="ItemName" class="form-control" placeholder="Item display name" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="2" placeholder="Optional description"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-0">
                                <label class="form-label">Unit</label>
                                <input name="Unit" class="form-control" placeholder="PCS, BOX, KG..." />
                            </div>
                            <div class="col-6 mb-0">
                                <label class="form-label">Min Stock</label>
                                <input name="MinStock" type="number" class="form-control" value="0" min="0" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-save me-1"></i>Save Item</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Item Modal -->
    <div class="modal fade" id="editItemModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header is-dark">
                    <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form id="editItemForm" action="/items/edit/0" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Item Code <span style="color:var(--danger)">*</span></label>
                            <input id="editItemCode" name="ItemCode" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Item Name <span style="color:var(--danger)">*</span></label>
                            <input id="editItemName" name="ItemName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea id="editItemDesc" name="Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-0">
                                <label class="form-label">Unit</label>
                                <input id="editItemUnit" name="Unit" class="form-control" />
                            </div>
                            <div class="col-6 mb-0">
                                <label class="form-label">Min Stock</label>
                                <input id="editItemMin" name="MinStock" type="number" class="form-control" min="0" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-save me-1"></i>Update Item</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteItemModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header is-dark">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="font-size:13px;">
                    Delete item <strong id="deleteItemLabel"></strong>? This action cannot be undone.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form id="deleteItemForm" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () { $('#itemTable').DataTable({ pageLength: 25 }); });

        bindModalForm('createItemForm', 'createItemModal');
        bindModalForm('editItemForm', 'editItemModal');
        setupDeleteButtons('.btn-delete-item', 'deleteItemModal', 'deleteItemForm', 'deleteItemLabel');

        // Bind delete form AJAX
        var deleteForm = document.getElementById('deleteItemForm');
        if (deleteForm) {
            deleteForm.addEventListener('submit', function (e) {
                e.preventDefault();
                var token = deleteForm.querySelector('[name="__RequestVerificationToken"]').value;
                fetch(deleteForm.action, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': token },
                    body: new FormData(deleteForm)
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    bootstrap.Modal.getInstance(document.getElementById('deleteItemModal')).hide();
                    showToast(d.message, d.success ? 'success' : 'error');
                    if (d.success) setTimeout(function () { location.reload(); }, 600);
                });
            });
        }

        // Populate edit modal
        document.querySelectorAll('.btn-edit-item').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var id = this.dataset.id;
                document.getElementById('editItemCode').value = this.dataset.code;
                document.getElementById('editItemName').value = this.dataset.name;
                document.getElementById('editItemDesc').value = this.dataset.desc || '';
                document.getElementById('editItemUnit').value = this.dataset.unit || '';
                document.getElementById('editItemMin').value = this.dataset.min || '0';
                document.getElementById('editItemForm').action = '/items/edit/' + id;
                new bootstrap.Modal(document.getElementById('editItemModal')).show();
            });
        });
    </script>
}
