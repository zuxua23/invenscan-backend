@using InvenScan.DTO.Response
@model List<ItemResponse>
@{ ViewData["Title"] = "Items"; }

<div class="page-header">
    <h1 class="page-title">Items</h1>
    @if (User.IsInRole("ADMIN"))
    {
        <a asp-controller="ItemWeb" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Add Item
        </a>
    }
</div>

<div class="is-card">
    <table id="itemTable" class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Item Code</th>
                <th>Item Name</th>
                <th>Unit</th>
                <th>Min Stock</th>
                <th>Created</th>
                @if (User.IsInRole("ADMIN"))
                {
                    <th style="width:100px">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><code>@item.ItemCode</code></td>
                    <td>@item.ItemName</td>
                    <td style="color:var(--text-secondary)">@item.Unit</td>
                    <td style="color:var(--text-secondary)">@item.MinStock</td>
                    <td style="color:var(--text-hint);font-size:12px">@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                    @if (User.IsInRole("ADMIN"))
                    {
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-controller="ItemWeb" asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary py-0">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-controller="ItemWeb" asp-action="Delete" asp-route-id="@item.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete @item.ItemCode?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger py-0">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () { $('#itemTable').DataTable({ pageLength: 25 }); });
    </script>
}
