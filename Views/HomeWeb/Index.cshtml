@using InvenScan.DTO.Response
@model DashboardSummaryResponse
@{ ViewData["Title"] = "Dashboard"; }

<div class="page-header">
    <h1 class="page-title">Dashboard</h1>
    <span style="font-size:12px;color:var(--text-hint)">@DateTime.UtcNow.ToString("dddd, dd MMMM yyyy") UTC</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Total Items</div>
            <div class="kpi-value is-teal">@Model.TotalItems</div>
            <div class="kpi-sub"><i class="bi bi-box-seam me-1"></i>Active items</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Locations</div>
            <div class="kpi-value is-teal">@Model.TotalLocations</div>
            <div class="kpi-sub"><i class="bi bi-geo-alt me-1"></i>Active locations</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Registered Tags</div>
            <div class="kpi-value">@Model.TotalTags</div>
            <div class="kpi-sub"><i class="bi bi-tag me-1"></i>RFID / Barcode</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Stock Taking</div>
            <div class="kpi-value is-warn">@Model.ActiveStockTakingSessions</div>
            <div class="kpi-sub"><i class="bi bi-clipboard-check me-1"></i>Active sessions</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Stock Prep</div>
            <div class="kpi-value is-warn">@Model.PendingStockPrepDocs</div>
            <div class="kpi-sub"><i class="bi bi-bag-check me-1"></i>Pending docs</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Active Users</div>
            <div class="kpi-value is-teal">@Model.TotalUsers</div>
            <div class="kpi-sub"><i class="bi bi-people me-1"></i>System users</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card p-3">
            <div class="fw-semibold mb-3" style="font-size:13px;color:var(--navy)">
                <i class="bi bi-lightning-fill me-2" style="color:var(--warning)"></i>Quick Actions
            </div>
            @if (User.IsInRole("ADMIN"))
            {
                <a asp-controller="StockTakingWeb" asp-action="Index" class="quick-action-link">
                    <i class="bi bi-clipboard-plus"></i>New Stock Taking Session
                </a>
                <a asp-controller="StockPrepWeb" asp-action="Create" class="quick-action-link">
                    <i class="bi bi-plus-circle"></i>Create Picking List
                </a>
                <a asp-controller="ItemWeb" asp-action="Create" class="quick-action-link">
                    <i class="bi bi-box-seam"></i>Add New Item
                </a>
            }
            <a asp-controller="StockTakingWeb" asp-action="Index" class="quick-action-link">
                <i class="bi bi-clock-history"></i>View Stock Taking History
            </a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-3">
            <div class="fw-semibold mb-3" style="font-size:13px;color:var(--navy)">
                <i class="bi bi-info-circle me-2" style="color:var(--teal)"></i>System Info
            </div>
            <table class="table table-sm table-borderless mb-0">
                <tr>
                    <td style="color:var(--text-hint);font-size:12px;width:50%">Product</td>
                    <td style="font-size:12px;font-weight:600">InvenScan v1.0.0</td>
                </tr>
                <tr>
                    <td style="color:var(--text-hint);font-size:12px">Framework</td>
                    <td style="font-size:12px;font-weight:600">ASP.NET Core 8</td>
                </tr>
                <tr>
                    <td style="color:var(--text-hint);font-size:12px">Database</td>
                    <td style="font-size:12px;font-weight:600">SQL Server</td>
                </tr>
                <tr>
                    <td style="color:var(--text-hint);font-size:12px">Server Time</td>
                    <td style="font-size:12px;font-weight:600">@DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm") UTC</td>
                </tr>
            </table>
        </div>
    </div>
</div>
