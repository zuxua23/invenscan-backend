@using InvenScan.DTO.Response
@model DashboardSummaryResponse
@{ ViewData["Title"] = "Dashboard"; }

<div class="page-header">
    <h1 class="page-title">Dashboard</h1>
    <span style="font-size:12px;color:var(--text-hint)">@DateTime.UtcNow.ToString("dddd, dd MMMM yyyy") UTC</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Total Items</div>
            <div class="kpi-value is-teal">@Model.TotalItems</div>
            <div class="kpi-sub"><i class="bi bi-box-seam me-1"></i>Active items</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Locations</div>
            <div class="kpi-value is-teal">@Model.TotalLocations</div>
            <div class="kpi-sub"><i class="bi bi-geo-alt me-1"></i>Active locations</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Registered Tags</div>
            <div class="kpi-value">@Model.TotalTags</div>
            <div class="kpi-sub"><i class="bi bi-tag me-1"></i>RFID / Barcode</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Stock Taking</div>
            <div class="kpi-value is-warn">@Model.ActiveStockTakingSessions</div>
            <div class="kpi-sub"><i class="bi bi-clipboard-check me-1"></i>Active sessions</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Stock Prep</div>
            <div class="kpi-value is-warn">@Model.PendingStockPrepDocs</div>
            <div class="kpi-sub"><i class="bi bi-bag-check me-1"></i>Pending docs</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Active Users</div>
            <div class="kpi-value is-teal">@Model.TotalUsers</div>
            <div class="kpi-sub"><i class="bi bi-people me-1"></i>System users</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="chart-card">
            <div class="chart-title">Stock In — Last 7 Days</div>
            <canvas id="chartStockIn" height="180"></canvas>
        </div>
    </div>
    <div class="col-md-3">
        <div class="chart-card">
            <div class="chart-title">Tag Status Distribution</div>
            <canvas id="chartTagStatus" height="180"></canvas>
        </div>
    </div>
    <div class="col-md-4">
        <div class="chart-card">
            <div class="chart-title">Stock Taking — Last 4 Weeks</div>
            <canvas id="chartStockTaking" height="180"></canvas>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card p-3">
            <div class="fw-semibold mb-3" style="font-size:13px;color:var(--navy)">
                <i class="bi bi-lightning-fill me-2" style="color:var(--warning)"></i>Quick Actions
            </div>
            @if (User.IsInRole("ADMIN"))
            {
                <a asp-controller="StockTakingWeb" asp-action="Index" class="quick-action-link">
                    <i class="bi bi-clipboard-plus"></i>New Stock Taking Session
                </a>
                <a asp-controller="StockPrepWeb" asp-action="Create" class="quick-action-link">
                    <i class="bi bi-plus-circle"></i>Create Picking List
                </a>
                <a asp-controller="ItemWeb" asp-action="Index" class="quick-action-link">
                    <i class="bi bi-box-seam"></i>Manage Items
                </a>
            }
            <a asp-controller="TransactionHistoryWeb" asp-action="Index" class="quick-action-link">
                <i class="bi bi-clock-history"></i>View Transaction History
            </a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-3">
            <div class="fw-semibold mb-3" style="font-size:13px;color:var(--navy)">
                <i class="bi bi-info-circle me-2" style="color:var(--teal)"></i>System Info
            </div>
            <table class="table table-sm table-borderless mb-0">
                <tr>
                    <td style="color:var(--text-hint);font-size:12px;width:50%">Product</td>
                    <td style="font-size:12px;font-weight:600">InvenScan v1.0.0</td>
                </tr>
                <tr>
                    <td style="color:var(--text-hint);font-size:12px">Framework</td>
                    <td style="font-size:12px;font-weight:600">ASP.NET Core 8</td>
                </tr>
                <tr>
                    <td style="color:var(--text-hint);font-size:12px">Database</td>
                    <td style="font-size:12px;font-weight:600">SQL Server</td>
                </tr>
                <tr>
                    <td style="color:var(--text-hint);font-size:12px">Server Time</td>
                    <td style="font-size:12px;font-weight:600">@DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm") UTC</td>
                </tr>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var chartData = @Html.Raw(ViewBag.ChartData ?? "{}");
    var teal = '#1D9E75', tealLight = '#5DCAA5', tealBg = 'rgba(29,158,117,0.12)';
    var navy = '#1A2332', warning = '#EF9F27', danger = '#E24B4A';

    // Bar chart - Stock In per day
    new Chart(document.getElementById('chartStockIn'), {
        type: 'bar',
        data: {
            labels: chartData.stockInLabels || [],
            datasets: [{
                label: 'Stock In',
                data: chartData.stockInValues || [],
                backgroundColor: tealBg,
                borderColor: teal,
                borderWidth: 1.5,
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { precision: 0, font: { size: 11 } }, grid: { color: 'rgba(0,0,0,0.04)' } },
                x: { ticks: { font: { size: 11 } }, grid: { display: false } }
            }
        }
    });

    // Doughnut chart - Tag status
    new Chart(document.getElementById('chartTagStatus'), {
        type: 'doughnut',
        data: {
            labels: chartData.tagStatusLabels || ['In Stock', 'Out', 'Unknown'],
            datasets: [{
                data: chartData.tagStatusValues || [0, 0, 0],
                backgroundColor: [teal, danger, warning],
                borderWidth: 0,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            cutout: '68%',
            plugins: {
                legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 10, boxWidth: 10 } }
            }
        }
    });

    // Line chart - Stock Taking per week
    new Chart(document.getElementById('chartStockTaking'), {
        type: 'line',
        data: {
            labels: chartData.stockTakingLabels || [],
            datasets: [{
                label: 'Sessions',
                data: chartData.stockTakingValues || [],
                borderColor: navy,
                backgroundColor: 'rgba(26,35,50,0.07)',
                borderWidth: 2,
                pointBackgroundColor: navy,
                pointRadius: 4,
                tension: 0.3,
                fill: true
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { precision: 0, font: { size: 11 } }, grid: { color: 'rgba(0,0,0,0.04)' } },
                x: { ticks: { font: { size: 11 } }, grid: { display: false } }
            }
        }
    });
</script>
}
