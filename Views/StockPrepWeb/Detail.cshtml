@using InvenScan.DTO.Response
@model StockPrepResponse
@{ ViewData["Title"] = $"Picking List {Model.DocNumber}"; }

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-controller="StockPrepWeb" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="page-title mb-0">Picking List Detail</h1>
    </div>
</div>

<div class="card mb-3">
    <div class="detail-header">
        <div class="detail-header-item">
            <div class="dh-label">Doc Number</div>
            <div class="dh-value"><code>@Model.DocNumber</code></div>
        </div>
        <div class="detail-header-item">
            <div class="dh-label">Status</div>
            <div class="dh-value">
                @switch (Model.Status)
                {
                    case "OPEN":
                        <span class="badge-teal">OPEN</span>
                        break;
                    case "IN_PROGRESS":
                        <span class="badge-warning">IN PROGRESS</span>
                        break;
                    default:
                        <span class="badge-gray">DONE</span>
                        break;
                }
            </div>
        </div>
        <div class="detail-header-item">
            <div class="dh-label">Progress</div>
            <div class="dh-value">@Model.PickedItems / @Model.TotalItems picked</div>
        </div>
        <div class="detail-header-item">
            <div class="dh-label">Created By</div>
            <div class="dh-value is-hint">@Model.CreatedBy</div>
        </div>
        <div class="detail-header-item">
            <div class="dh-label">Created</div>
            <div class="dh-value is-hint">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
        </div>
    </div>
</div>

<div class="is-card">
    <table id="detailTable" class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Item Code</th>
                <th>Item Name</th>
                <th>Location</th>
                <th>Requested</th>
                <th>Picked</th>
                <th>Status</th>
                <th>Scanned Code</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Details)
            {
                <tr>
                    <td><code>@d.ItemCode</code></td>
                    <td>@d.ItemName</td>
                    <td style="color:var(--text-secondary);font-size:12px">@d.LocationCode — @d.LocationName</td>
                    <td>@d.RequestedQty @d.Unit</td>
                    <td style="font-weight:600;color:@(d.PickedQty >= d.RequestedQty ? "var(--teal)" : "inherit")">@d.PickedQty</td>
                    <td>
                        @if (d.Status == "PICKED")
                        {
                            <span class="badge-teal">PICKED</span>
                        }
                        else
                        {
                            <span class="badge-gray">PENDING</span>
                        }
                    </td>
                    <td><code style="font-size:11px;color:var(--text-hint)">@(string.IsNullOrWhiteSpace(d.ScannedCode) ? "—" : d.ScannedCode)</code></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>$(document).ready(function () { $('#detailTable').DataTable({ pageLength: 50, paging: false }); });</script>
}
