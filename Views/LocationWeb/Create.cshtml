@using InvenScan.DTO.Request
@model LocationCreateRequest
@{ ViewData["Title"] = "Add Location"; }

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-controller="LocationWeb" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="page-title mb-0">Add Location</h1>
    </div>
</div>

<div style="max-width:480px">
    <div class="card p-4">
        @if (ViewData["Error"] != null)
        {
            <div class="alert-is alert-is-danger mb-3">
                <i class="bi bi-exclamation-triangle-fill"></i>@ViewData["Error"]
            </div>
        }
        <form asp-controller="LocationWeb" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Location Code <span style="color:var(--danger)">*</span></label>
                <input name="LocationCode" class="form-control" value="@Model?.LocationCode" placeholder="e.g. LOC-004" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Location Name <span style="color:var(--danger)">*</span></label>
                <input name="LocationName" class="form-control" value="@Model?.LocationName" placeholder="Location display name" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="Description" class="form-control" rows="2">@Model?.Description</textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-save me-1"></i>Save Location
            </button>
        </form>
    </div>
</div>
