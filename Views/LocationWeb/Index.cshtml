@using InvenScan.DTO.Response
@model List<LocationResponse>
@{ ViewData["Title"] = "Locations"; }

<div class="d-flex justify-content-end mb-3">
    @if (User.IsInRole("ADMIN"))
    {
        <a asp-controller="LocationWeb" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Add Location
        </a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <table id="locationTable" class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Location Code</th>
                    <th>Location Name</th>
                    <th>Description</th>
                    <th>Created</th>
                    @if (User.IsInRole("ADMIN"))
                    {
                        <th style="width:120px">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var loc in Model)
                {
                    <tr>
                        <td><code>@loc.LocationCode</code></td>
                        <td>@loc.LocationName</td>
                        <td class="text-muted">@loc.Description</td>
                        <td class="text-muted small">@loc.CreatedAt.ToString("yyyy-MM-dd")</td>
                        @if (User.IsInRole("ADMIN"))
                        {
                            <td>
                                <a asp-controller="LocationWeb" asp-action="Edit" asp-route-id="@loc.Id"
                                   class="btn btn-sm btn-outline-secondary py-0">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-controller="LocationWeb" asp-action="Delete" asp-route-id="@loc.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete @loc.LocationCode?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger py-0">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>$(document).ready(function () { $('#locationTable').DataTable({ pageLength: 25 }); });</script>
}
