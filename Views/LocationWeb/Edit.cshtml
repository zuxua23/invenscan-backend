@using InvenScan.Entity
@model Location
@{ ViewData["Title"] = "Edit Location"; }

<div style="max-width:480px">
    <a asp-controller="LocationWeb" asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <div class="card p-4">
        @if (ViewData["Error"] != null)
        {
            <div class="alert alert-danger py-2 small">@ViewData["Error"]</div>
        }
        <form asp-controller="LocationWeb" asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold small">Location Code <span class="text-danger">*</span></label>
                <input name="LocationCode" class="form-control" value="@Model.LocationCode" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold small">Location Name <span class="text-danger">*</span></label>
                <input name="LocationName" class="form-control" value="@Model.LocationName" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold small">Description</label>
                <textarea name="Description" class="form-control" rows="2">@Model.Description</textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-save me-1"></i>Update Location
            </button>
        </form>
    </div>
</div>
