@using InvenScan.DTO.Request
@model UserCreateRequest
@{ ViewData["Title"] = "Add User"; }

<div style="max-width:480px">
    <a asp-controller="UserWeb" asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <div class="card p-4">
        @if (ViewData["Error"] != null)
        {
            <div class="alert alert-danger py-2 small">@ViewData["Error"]</div>
        }
        <form asp-controller="UserWeb" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold small">Username <span class="text-danger">*</span></label>
                <input name="UserId" class="form-control" value="@Model?.UserId" placeholder="e.g. operator2" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold small">Full Name</label>
                <input name="FullName" class="form-control" value="@Model?.FullName" placeholder="Display name" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold small">Password <span class="text-danger">*</span></label>
                <input name="Password" type="password" class="form-control" placeholder="Minimum 6 characters" required minlength="6" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold small">Role</label>
                <select name="Role" class="form-select">
                    <option value="OPERATOR" selected>OPERATOR</option>
                    <option value="ADMIN">ADMIN</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-save me-1"></i>Create User
            </button>
        </form>
    </div>
</div>
