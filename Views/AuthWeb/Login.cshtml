@{
    ViewData["Title"] = "Login";
    Layout = "_AuthLayout";
}

<!-- Toast container for login page -->
<div id="toast-container" style="position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;"></div>

<div class="login-page">
    <div>
        <div class="login-card">
            <div class="login-logo">
                <i class="bi bi-upc-scan"></i>
            </div>
            <div class="login-title">InvenScan</div>
            <div class="login-subtitle">Inventory Management System</div>

            @if (ViewData["Error"] != null)
            {
                <div class="alert-is alert-is-danger mb-4">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @ViewData["Error"]
                </div>
            }

            <form method="post" action="/login">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <div class="input-group-is">
                        <span class="ig-prefix"><i class="bi bi-person"></i></span>
                        <input type="text" name="userId" placeholder="Enter username" required autocomplete="username" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-group-is">
                        <span class="ig-prefix"><i class="bi bi-lock"></i></span>
                        <input type="password" name="password" placeholder="Enter password" required autocomplete="current-password" />
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </button>
            </form>

            <div class="login-hint">Default credentials: admin / admin123</div>
        </div>
    </div>
</div>

<!-- DB Settings floating button -->
<button class="btn-db-config" data-bs-toggle="modal" data-bs-target="#dbConfigModal">
    <i class="bi bi-database-gear"></i> DB Settings
</button>

<!-- DB Config Modal -->
<div class="modal fade" id="dbConfigModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header is-dark">
                <h5 class="modal-title"><i class="bi bi-database-gear me-2"></i>Database Configuration</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p style="font-size:12px;color:var(--text-hint)" class="mb-3">
                    Configure the database connection for this application. The connection will be tested before saving.
                </p>
                <div class="mb-3">
                    <label class="form-label">Server <span style="color:var(--danger)">*</span></label>
                    <input type="text" id="dbServer" class="form-control" placeholder="e.g. localhost or 192.168.1.10" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Database Name <span style="color:var(--danger)">*</span></label>
                    <input type="text" id="dbName" class="form-control" placeholder="e.g. InvenScanDB" />
                </div>
                <div class="row">
                    <div class="col-8 mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" id="dbUser" class="form-control" placeholder="Leave blank for Windows Auth" />
                    </div>
                    <div class="col-4 mb-3">
                        <label class="form-label">Port</label>
                        <input type="number" id="dbPort" class="form-control" placeholder="1433" value="1433" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" id="dbPassword" class="form-control" placeholder="Leave blank for Windows Auth" />
                </div>
                <div id="dbConfigMsg" class="alert-is d-none" style="margin-bottom:0"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-outline-primary" id="btnTestConn">
                    <i class="bi bi-plug me-1"></i>Test Connection
                </button>
                <button type="button" class="btn btn-sm btn-primary" id="btnSaveDb">
                    <i class="bi bi-save me-1"></i>Save & Apply
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function getDbPayload() {
        return {
            server: document.getElementById('dbServer').value.trim(),
            database: document.getElementById('dbName').value.trim(),
            username: document.getElementById('dbUser').value.trim(),
            password: document.getElementById('dbPassword').value,
            port: document.getElementById('dbPort').value || '1433'
        };
    }

    function showDbMsg(msg, isSuccess) {
        var el = document.getElementById('dbConfigMsg');
        el.className = 'alert-is ' + (isSuccess ? 'alert-is-success' : 'alert-is-danger');
        el.innerHTML = '<i class="bi ' + (isSuccess ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill') + '"></i> ' + msg;
    }

    document.getElementById('btnTestConn').addEventListener('click', function () {
        var btn = this;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Testing...';
        fetch('/api/config/database/test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(getDbPayload())
        })
        .then(function (r) { return r.json(); })
        .then(function (d) { showDbMsg(d.message, d.success); })
        .catch(function () { showDbMsg('Request failed.', false); })
        .finally(function () {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-plug me-1"></i>Test Connection';
        });
    });

    document.getElementById('btnSaveDb').addEventListener('click', function () {
        var btn = this;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
        fetch('/api/config/database', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(getDbPayload())
        })
        .then(function (r) { return r.json(); })
        .then(function (d) { showDbMsg(d.message, d.success); })
        .catch(function () { showDbMsg('Request failed.', false); })
        .finally(function () {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-save me-1"></i>Save & Apply';
        });
    });
</script>
}
