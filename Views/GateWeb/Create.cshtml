@using InvenScan.Entity
@model GateConfig
@{ ViewData["Title"] = "Add Gate"; }

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a href="/gate" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <h1 class="page-title mb-0">Add Gate</h1>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <form method="post" action="/gate/create">
            @Html.AntiForgeryToken()

            <div class="is-card mb-3">
                <div class="mb-3">
                    <label class="form-label" style="font-size:12px;color:var(--text-secondary)">Gate Name <span class="text-danger">*</span></label>
                    <input name="GateName" value="@Model.GateName" class="form-control form-control-sm"
                           placeholder="e.g. Warehouse Exit Gate" required />
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:12px;color:var(--text-secondary)">Gate Code <span class="text-danger">*</span></label>
                    <input name="GateCode" value="@Model.GateCode" class="form-control form-control-sm"
                           placeholder="e.g. GATE-01" required />
                    <div style="font-size:11px;color:var(--text-hint);margin-top:4px">Unique identifier. Used in auto-generated doc numbers.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:12px;color:var(--text-secondary)">Location</label>
                    <select name="LocationId" class="form-select form-select-sm">
                        <option value="">— No location —</option>
                        @foreach (var loc in (dynamic)ViewBag.Locations)
                        {
                            <option value="@loc.Id">@loc.LocationCode — @loc.LocationName</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="chkActive" checked="@Model.IsActive" />
                        <label class="form-check-label" for="chkActive" style="font-size:13px">Active</label>
                    </div>
                </div>
            </div>

            <div class="is-card mb-3">
                <div class="mb-1" style="font-size:13px;font-weight:600;color:var(--text-primary)">API Key</div>
                <div style="font-size:11px;color:var(--text-hint);margin-bottom:10px">
                    Provide this key to your RFID reader. The reader must send it as <code>X-Gate-Api-Key</code> header.
                </div>
                <div class="d-flex gap-2">
                    <input type="text" id="apiKeyInput" name="ApiKey" value="@Model.ApiKey"
                           class="form-control form-control-sm" style="font-family:monospace;font-size:12px" readonly />
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="regenerateKey()" style="white-space:nowrap">
                        <i class="bi bi-arrow-clockwise me-1"></i>Generate New
                    </button>
                </div>
            </div>

            <div class="is-card mb-3">
                <div class="mb-1" style="font-size:13px;font-weight:600;color:var(--text-primary)">Field Mapping</div>
                <div style="font-size:11px;color:var(--text-hint);margin-bottom:10px">
                    Map your reader's field names to InvenScan fields. Left = InvenScan field, Right = your reader's field name.
                </div>
                <table class="table table-sm mb-2" id="mappingTable" style="font-size:12px">
                    <thead>
                        <tr>
                            <th style="width:40%;color:var(--text-secondary)">InvenScan Field</th>
                            <th style="color:var(--text-secondary)">Reader Field Name</th>
                            <th style="width:40px"></th>
                        </tr>
                    </thead>
                    <tbody id="mappingBody">
                    </tbody>
                </table>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addMappingRow()">
                    <i class="bi bi-plus-lg me-1"></i>Add Row
                </button>
                <input type="hidden" name="FieldMapping" id="fieldMappingInput" value="@Model.FieldMapping" />
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a href="/gate" class="btn btn-sm btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-sm btn-primary" onclick="syncMapping()">
                    <i class="bi bi-check-lg me-1"></i>Create Gate
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    var ourFields = ['epc', 'timestamp', 'antenna', 'rssi', 'reader'];

    function addMappingRow(ourVal, readerVal) {
        var tbody = document.getElementById('mappingBody');
        var row = document.createElement('tr');
        row.innerHTML = '<td><select class="form-select form-select-sm mapping-our">'
            + ourFields.map(f => '<option value="' + f + '"' + (f === ourVal ? ' selected' : '') + '>' + f + '</option>').join('')
            + '</select></td>'
            + '<td><input type="text" class="form-control form-control-sm mapping-reader" value="' + (readerVal || '') + '" placeholder="e.g. EPC" /></td>'
            + '<td><button type="button" class="btn btn-sm btn-outline-danger py-0" onclick="this.closest(\'tr\').remove()"><i class="bi bi-x"></i></button></td>';
        tbody.appendChild(row);
    }

    function syncMapping() {
        var obj = {};
        document.querySelectorAll('#mappingBody tr').forEach(function (row) {
            var ourField = row.querySelector('.mapping-our')?.value;
            var readerField = row.querySelector('.mapping-reader')?.value;
            if (ourField && readerField) obj[ourField] = readerField;
        });
        if (Object.keys(obj).length === 0) obj = { epc: 'epc' };
        document.getElementById('fieldMappingInput').value = JSON.stringify(obj);
        return true;
    }

    function regenerateKey() {
        var key = Array.from(crypto.getRandomValues(new Uint8Array(16)))
            .map(b => b.toString(16).padStart(2, '0')).join('');
        document.getElementById('apiKeyInput').value = key;
    }

    // Init from existing FieldMapping
    (function () {
        try {
            var mapping = JSON.parse('@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FieldMapping))');
            var parsed = JSON.parse(mapping);
            Object.entries(parsed).forEach(function ([k, v]) { addMappingRow(k, v); });
        } catch (e) {
            addMappingRow('epc', 'epc');
        }
    })();
</script>
}
