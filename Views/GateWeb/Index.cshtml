@using InvenScan.Entity
@model List<GateConfig>
@{
    ViewData["Title"] = "Gate Monitor";
    var locationList = ViewBag.Locations as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var newApiKey = ViewBag.NewApiKey as string ?? "";
}

<div class="page-header">
    <h1 class="page-title">Gate Monitor</h1>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createGateModal">
        <i class="bi bi-plus-lg me-1"></i>Add Gate
    </button>
</div>

<div class="is-card">
    <table id="gateTable" class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Gate Name</th>
                <th>Gate Code</th>
                <th>Location</th>
                <th>API Key</th>
                <th>Status</th>
                <th>Created</th>
                <th style="width:130px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var gate in Model)
            {
                <tr>
                    <td style="font-weight:500">@gate.GateName</td>
                    <td><code>@gate.GateCode</code></td>
                    <td style="color:var(--text-secondary);font-size:12px">
                        @if (gate.Location != null)
                        {
                            @($"{gate.Location.LocationCode} — {gate.Location.LocationName}")
                        }
                        else
                        {
                            <span style="color:var(--text-hint)">—</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <code id="apikey-@gate.Id" class="apikey-masked" style="font-size:11px;letter-spacing:1px">
                                ••••••••••••••••
                            </code>
                            <button class="btn-icon-sm" onclick="revealApiKey(@gate.Id, '@gate.ApiKey')" title="Reveal">
                                <i class="bi bi-eye" id="eye-icon-@gate.Id"></i>
                            </button>
                            <button class="btn-icon-sm" onclick="copyApiKey('@gate.ApiKey')" title="Copy">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                    </td>
                    <td>
                        @if (gate.IsActive)
                        {
                            <span class="badge-teal">Active</span>
                        }
                        else
                        {
                            <span class="badge-gray">Inactive</span>
                        }
                    </td>
                    <td style="color:var(--text-hint);font-size:12px">@gate.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="/gate/@gate.Id/log" class="btn btn-sm btn-outline-primary py-0" title="View Log">
                                <i class="bi bi-activity"></i>
                            </a>
                            <a href="/gate/@gate.Id/edit" class="btn btn-sm btn-outline-secondary py-0" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger py-0" title="Delete"
                                    onclick="confirmDelete(@gate.Id, '@gate.GateName')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Create Gate Modal -->
<div class="modal fade" id="createGateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header is-dark">
                <h5 class="modal-title"><i class="bi bi-router me-2"></i>Add Gate</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="createGateForm" action="/gate/create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-7">
                            <label class="form-label">Gate Name <span style="color:var(--danger)">*</span></label>
                            <input name="GateName" class="form-control" placeholder="e.g. Main Entrance Gate" required />
                        </div>
                        <div class="col-5">
                            <label class="form-label">Gate Code <span style="color:var(--danger)">*</span></label>
                            <input name="GateCode" class="form-control" placeholder="e.g. GATE-01" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <select name="LocationId" class="form-select">
                            <option value="">-- None --</option>
                            @foreach (var loc in locationList)
                            {
                                <option value="@loc.Id">@loc.LocationCode — @loc.LocationName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">API Key</label>
                        <div class="input-group">
                            <input id="newApiKeyInput" name="ApiKey" class="form-control" style="font-family:monospace;font-size:12px"
                                   value="@newApiKey" readonly />
                            <button type="button" class="btn btn-outline-secondary" onclick="regenerateNewKey()" title="Regenerate">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </div>
                        <div style="font-size:11px;color:var(--text-hint);margin-top:4px">Auto-generated. Buyer configures their RFID reader to use this key.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Field Mapping</label>
                        <table class="table table-sm mb-1" id="mappingTable">
                            <thead>
                                <tr style="font-size:12px;color:var(--text-hint)">
                                    <th>Reader Field</th>
                                    <th>Our Field</th>
                                    <th style="width:40px"></th>
                                </tr>
                            </thead>
                            <tbody id="mappingBody">
                                <tr>
                                    <td><input type="text" class="form-control form-control-sm mapping-reader" placeholder="e.g. EPC" value="epc" /></td>
                                    <td>
                                        <select class="form-select form-select-sm mapping-ours">
                                            <option value="epc" selected>epc</option>
                                            <option value="timestamp">timestamp</option>
                                            <option value="antenna">antenna</option>
                                        </select>
                                    </td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addMappingRow()">
                            <i class="bi bi-plus me-1"></i>Add Field
                        </button>
                        <input type="hidden" name="FieldMapping" id="fieldMappingInput" />
                    </div>
                    <div class="mb-0">
                        <div class="form-check">
                            <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="isActiveCheck" checked />
                            <label class="form-check-label" for="isActiveCheck" style="font-size:13px">Active</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-primary" onclick="syncMapping()">
                        <i class="bi bi-plus-lg me-1"></i>Add Gate
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header is-dark">
                <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Delete Gate</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:13px;">
                Delete gate <strong id="deleteGateName"></strong>? This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" class="mb-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        $('#gateTable').DataTable({ order: [[0, 'asc']], pageLength: 25 });
    });

    bindModalForm('createGateForm', 'createGateModal', function () {
        document.querySelector('[name="GateName"]').value = '';
        document.querySelector('[name="GateCode"]').value = '';
        document.querySelector('[name="LocationId"]').value = '';
        document.getElementById('isActiveCheck').checked = true;
        document.getElementById('mappingBody').innerHTML =
            '<tr><td><input type="text" class="form-control form-control-sm mapping-reader" value="epc" /></td>' +
            '<td><select class="form-select form-select-sm mapping-ours"><option value="epc" selected>epc</option>' +
            '<option value="timestamp">timestamp</option><option value="antenna">antenna</option></select></td><td></td></tr>';
        regenerateNewKey();
    });

    var apiKeyVisible = {};
    function revealApiKey(id, key) {
        var el = document.getElementById('apikey-' + id);
        var icon = document.getElementById('eye-icon-' + id);
        if (apiKeyVisible[id]) {
            el.textContent = '••••••••••••••••';
            icon.className = 'bi bi-eye';
            apiKeyVisible[id] = false;
        } else {
            el.textContent = key;
            icon.className = 'bi bi-eye-slash';
            apiKeyVisible[id] = true;
        }
    }

    function copyApiKey(key) {
        navigator.clipboard.writeText(key).then(function () {
            showToast('API key copied to clipboard.', 'success');
        });
    }

    function confirmDelete(id, name) {
        document.getElementById('deleteGateName').textContent = name;
        document.getElementById('deleteForm').action = '/gate/' + id + '/delete';
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }

    function regenerateNewKey() {
        var uuid = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
            var r = Math.random() * 16 | 0;
            var v = c === 'x' ? r : (r & 0x3 | 0x8);
            return v.toString(16);
        });
        document.getElementById('newApiKeyInput').value = uuid;
    }

    function addMappingRow() {
        var row = document.createElement('tr');
        row.innerHTML =
            '<td><input type="text" class="form-control form-control-sm mapping-reader" placeholder="reader field" /></td>' +
            '<td><select class="form-select form-select-sm mapping-ours">' +
            '<option value="epc">epc</option><option value="timestamp">timestamp</option><option value="antenna">antenna</option>' +
            '</select></td>' +
            '<td><button type="button" class="btn btn-sm btn-outline-danger py-0" onclick="this.closest(\'tr\').remove()"><i class="bi bi-x"></i></button></td>';
        document.getElementById('mappingBody').appendChild(row);
    }

    function syncMapping() {
        var mapping = {};
        document.querySelectorAll('#mappingBody tr').forEach(function (row) {
            var readerField = row.querySelector('.mapping-reader')?.value?.trim();
            var oursField = row.querySelector('.mapping-ours')?.value?.trim();
            if (readerField && oursField) mapping[readerField] = oursField;
        });
        document.getElementById('fieldMappingInput').value = JSON.stringify(mapping);
    }
</script>
}
